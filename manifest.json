{
  "manifest_version": 2,
  "name": "WitchBlock",
  "version": "1.0.1",
  "description": "Strips server-side stitched ads from Twitch HLS playlists. Works by injecting a fetch hook into the Amazon IVS WASM worker before it initializes.",
  "homepage_url": "https://github.com/2u841r/witchblock",
  "browser_specific_settings": {
    "gecko": {
      "id": "witchblock@ZubairIbnZamir",
      "strict_min_version": "58.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://www.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
