{
  "manifest_version": 2,
  "name": "WitchBlock",
  "version": "1.0.0",
  "description": "Strips server-side stitched ads from Twitch HLS playlists. Works by injecting a fetch hook into the Amazon IVS WASM worker before it initializes.",
  "homepage_url": "https://github.com/2u841r/witchblock",
  "browser_specific_settings": {
    "gecko": {
      "id": "witchblock@ZubairIbnZamir",
      "strict_min_version": "57.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "background": {
    "scripts": ["background.js"]
  }
}
